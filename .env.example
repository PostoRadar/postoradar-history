# Porta do servidor HTTP.
PORT=3335

# Conexão com o Postgres do serviço de Histórico (um banco por serviço).
DATABASE_URL=postgresql://postoradar_history:postoradar_history@localhost:5433/postoradar_history?schema=public

# Brokers do Kafka (separados por vírgula). No compose interno use kafka:9094.
KAFKA_BROKERS=localhost:9092
